# Aptfile: one package per line (apt package names).
# Annotations after '#' on a line control install.sh behavior:
#   required       - exit non-zero if tool still missing after install
#   script-fallback - install via official script if apt package is unavailable/outdated
#   group:<name>   - informational grouping (latex, pdf, font, cli, editor)
#   font:nerd-manual - print a manual-install hint after setup

batcat
ca-certificates
cmake
curl                  # required
eza                   # script-fallback
# Plain Fira Code (not Nerd-patched). For Starship/Kitty icons, install FiraCode Nerd Font from https://www.nerdfonts.com/font-downloads
fonts-firacode        # font:nerd-manual
gh                    # required script-fallback
lazygit
neovim                # required
git                   # required
kitty                 # required script-fallback
pipx                  # required
starship              # required script-fallback
tailscale             # script-fallback
tmux                  # required
unzip
wget
zoxide                # required script-fallback
zsh                   # required
latexmk               # group:latex
texlive-latex-extra   # group:latex
texlive-fonts-recommended # group:latex
texlive-extra-utils   # group:latex
zathura               # group:pdf
biber                 # group:latex
xdotool
ripgrep
fd-find
